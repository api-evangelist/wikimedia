{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/list_write.json",
  "title": "list",
  "description": "Schema for list_write from the Wikimedia REST API",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "Planets"
    },
    "description": {
      "type": "string",
      "example": "Planets of the Solar System"
    }
  },
  "required": [
    "name"
  ]
}