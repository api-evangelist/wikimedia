{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/cx_dict.json",
  "title": "cx_dict",
  "description": "Schema for cx_dict from the Wikimedia REST API",
  "type": "object",
  "properties": {
    "source": {
      "type": "string",
      "description": "the original word to look up"
    },
    "translations": {
      "type": "array",
      "description": "the translations found",
      "items": {
        "type": "object",
        "properties": {
          "phrase": {
            "type": "string",
            "description": "the translated phrase"
          },
          "info": {
            "type": "string",
            "description": "extra information about the phrase"
          },
          "sources": {
            "type": "string",
            "description": "the source dictionary used for the translation"
          }
        }
      }
    }
  }
}