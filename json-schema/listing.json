{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/listing.json",
  "title": "listing",
  "description": "The result format for listings",
  "required": [
    "items"
  ],
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "_links": {
      "type": "object",
      "properties": {
        "next": {
          "type": "object",
          "properties": {
            "href": {
              "type": "string",
              "description": "Relative link to next result page."
            }
          }
        }
      }
    }
  }
}