{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/snapshot.json",
  "title": "snapshot",
  "description": "Schema for snapshot from the Wikimedia Enterprise API",
  "type": "object",
  "properties": {
    "identifier": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "date_modified": {
      "type": "string"
    },
    "in_language": {
      "$ref": "#/components/schemas/language"
    },
    "is_part_of": {
      "$ref": "#/components/schemas/project"
    },
    "namespace": {
      "$ref": "#/components/schemas/article_namespace"
    },
    "size": {
      "$ref": "#/components/schemas/size"
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}