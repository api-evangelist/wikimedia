{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/result.json",
  "title": "result",
  "description": "Schema for result from the Wikimedia REST API",
  "required": [
    "title",
    "url",
    "itemType"
  ],
  "type": "object",
  "properties": {
    "itemType": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "url": {
      "type": "string"
    }
  }
}