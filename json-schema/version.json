{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/wikimedia/refs/heads/main/json-schema/version.json",
  "title": "version",
  "description": "Schema for version from the Wikimedia Enterprise API",
  "properties": {
    "comment": {
      "type": "string"
    },
    "editor": {
      "$ref": "#/components/schemas/editor"
    },
    "identifier": {
      "type": "integer"
    },
    "is_flagged_stable": {
      "type": "boolean"
    },
    "is_minor_edit": {
      "type": "boolean"
    },
    "noindex": {
      "type": "boolean"
    },
    "scores": {
      "$ref": "#/components/schemas/scores"
    },
    "maintenance_tags": {
      "$ref": "#/components/schemas/maintenance_tags"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "type": "object"
}